[global]
    monitor = 0
    follow = mouse
    geometry = "300x5-30+30"
    indicate_hidden = yes
    shrink = no
    transparency = 5
    notification_height = 0
    separator_height = 2
    padding = 8
    horizontal_padding = 8
    text_icon_padding = 8
    frame_width = 1
    frame_color = "#00ff00"
    separator_color = auto
    sort = yes
    idle_threshold = 120
    font = JetBrains Mono Nerd Font 11
    line_height = 0
    markup = full
    format = "<b>%s</b>\\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    icon_path = /usr/share/icons/Papirus/16x16/status/:/usr/share/icons/Papirus/16x16/apps/
    sticky_history = yes
    history_length = 20
    browser = /usr/bin/firefox
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 4
    ignore_dbusclose = false
    force_xwayland = false
    wayland_display = wayland-0

[urgency_low]
    background = "#000000"
    foreground = "#00ff00"
    timeout = 5

[urgency_normal]
    background = "#000000"
    foreground = "#00ff00"
    timeout = 8

[urgency_critical]
    background = "#330000"
    foreground = "#ff0000"
    frame_color = "#ff0000"
    timeout = 0
